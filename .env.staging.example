# ─────────────────────────────────────────────────────────────────────────────
# STAGING ENVIRONMENT — tuitionsinindia.in
# Copy this to /root/tuitionsinindia-staging/.env.staging on the VPS
# NEVER commit the real .env.staging file (it has secrets)
# ─────────────────────────────────────────────────────────────────────────────

# Database — staging DB, completely separate from production
DATABASE_URL="postgresql://tuitions_admin:staging_password_here@db:5432/tuitionsinindia_staging"
POSTGRES_USER=tuitions_admin
POSTGRES_PASSWORD=staging_password_here
POSTGRES_DB=tuitionsinindia_staging

# Site URL — points to the .in domain
NEXT_PUBLIC_BASE_URL=https://tuitionsinindia.in

# Auth — use DIFFERENT secrets from production so sessions don't cross
SESSION_SECRET=staging_session_secret_change_this_32chars_min
NEXTAUTH_SECRET=staging_nextauth_secret_change_this

# Google OAuth — same credentials as prod BUT add tuitionsinindia.in
# to Authorized redirect URIs in Google Cloud Console:
# https://tuitionsinindia.in/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Razorpay — USE TEST KEYS on staging, never live keys
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=test_secret_here
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxx

# Email (Resend) — use same or create a separate staging API key
# Send to @tuitionsinindia.in to avoid emailing real users
RESEND_API_KEY=re_staging_key_here

# SMS (Twilio) — use test credentials on staging
TWILIO_ACCOUNT_SID=ACtest...
TWILIO_AUTH_TOKEN=test_token
TWILIO_PHONE_NUMBER=+1234567890

# Admin
ADMIN_EMAIL=admin@tuitionsinindia.in
ADMIN_PASSWORD=StagingAdmin@123

# Cron — different keys so staging crons don't interfere with prod
CRON_SECRET=staging_cron_secret
AUDIT_SEED_KEY=staging_audit_key

# OTP bypass — always enabled on staging for testing
# Phones starting with 9999 always accept OTP 000000

# Feature flags
NODE_ENV=production
NEXT_PUBLIC_ENV=staging

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(cuid())
  name               String?
  email              String?            @unique
  emailVerified      DateTime?
  image              String?
  googleId           String?            @unique
  provider           String?            @default("phone")
  role               Role               @default(STUDENT)
  phone              String?            @unique
  phoneVerified      Boolean            @default(false)
  isProfileComplete  Boolean            @default(false)
  privacySettings    Json?              @default("{\"showPhonePublicly\": true, \"preferredContact\": \"PHONE\"}")
  notificationPrefs  Json?              @default("{\"emailMatches\": true, \"emailMessages\": true, \"emailPayments\": true, \"smsLeads\": false}")
  lat                Float?
  lng                Float?
  isVerified         Boolean            @default(false)
  isIdVerified       Boolean            @default(false)
  credits            Int                @default(0)
  subscriptionTier   SubscriptionTier   @default(FREE)
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionId     String?            @unique
  referralCode       String?            @unique
  referredById       String?
  referredBy         User?              @relation("Referrals", fields: [referredById], references: [id])
  referrals          User[]             @relation("Referrals")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  ads                AdSlot[]           @relation("UserAds")
  studentChats       ChatSession[]      @relation("StudentChats")
  tutorChats         ChatSession[]      @relation("TutorChats")
  courses            Course[]           @relation("InstituteCourses")
  leadsPosted        Lead[]             @relation("LeadCreator")
  leadsUnlocked      LeadUnlock[]
  tutorListing       Listing?
  messagesSent       Message[]          @relation("SentMessages")
  reviewsGiven       Review[]           @relation("ReviewAuthor")
  reviewsReceived    Review[]           @relation("ReviewTarget")
  transactions       Transaction[]
  notifications      Notification[]
  studentTrials      TrialBooking[]     @relation("StudentTrials")
  tutorTrials        TrialBooking[]     @relation("TutorTrials")
}

model Listing {
  id                String      @id @default(cuid())
  tutorId           String      @unique
  title             String
  bio               String
  subjects          String[]
  grades            String[]
  locations         String[]
  hourlyRate        Int?
  rating            Float       @default(0)
  reviewCount       Int         @default(0)
  viewCount         Int         @default(0)
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  boards            String[]
  experience        Int?
  gender            String?
  teachingModes     String[]
  timings           String[]
  languages         String[]
  expertiseLevel    String?
  type              ListingType @default(PRIVATE)
  maxSeats          Int?        @default(1)
  enrolledCount     Int         @default(0)
  isInstitute       Boolean     @default(false)
  offersTrialClass  Boolean     @default(false)
  trialDuration     Int         @default(30)
  tutor             User        @relation(fields: [tutorId], references: [id], onDelete: Cascade)
}

model TrialBooking {
  id            String      @id @default(cuid())
  studentId     String
  tutorId       String
  subject       String
  preferredTime String
  message       String?
  duration      Int         @default(30)
  status        TrialStatus @default(PENDING)
  tutorNote     String?
  cancelReason  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  student       User        @relation("StudentTrials", fields: [studentId], references: [id], onDelete: Cascade)
  tutor         User        @relation("TutorTrials", fields: [tutorId], references: [id], onDelete: Cascade)
}

model Lead {
  id               String       @id @default(cuid())
  studentId        String
  subjects         String[]
  grades           String[]
  locations        String[]
  lat              Float?
  lng              Float?
  budget           Int?
  budgetMax        Int?
  modes            String[]
  boards           String[]
  timings          String[]
  genderPreference String?
  description      String
  isPremium        Boolean      @default(false)
  premiumTier      Int          @default(0)
  maxUnlocks       Int          @default(5)
  unlockCount      Int          @default(0)
  status           LeadStatus   @default(OPEN)
  type             LeadType     @default(ACADEMIC)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  student          User         @relation("LeadCreator", fields: [studentId], references: [id], onDelete: Cascade)
  unlockedBy       LeadUnlock[]
}

model LeadUnlock {
  id         String   @id @default(cuid())
  leadId     String
  tutorId    String
  unlockedAt DateTime @default(now())
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tutor      User     @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([leadId, tutorId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  authorId  String
  targetId  String
  createdAt DateTime @default(now())
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id])
}

model Course {
  id            String   @id @default(cuid())
  instituteId   String
  title         String
  description   String
  duration      String
  price         Int
  category      String
  timings       String[]
  maxSeats      Int?     @default(20)
  enrolledCount Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  institute     User     @relation("InstituteCourses", fields: [instituteId], references: [id], onDelete: Cascade)
}

model AdSlot {
  id        String   @id @default(cuid())
  userId    String
  type      AdType
  imageUrl  String?
  targetUrl String?
  startTime DateTime
  endTime   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("UserAds", fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                String            @id @default(cuid())
  userId            String
  amount            Int
  currency          String            @default("INR")
  status            TransactionStatus @default(PENDING)
  razorpayOrderId   String?           @unique
  razorpayPaymentId String?           @unique
  description       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id])
}

model ChatSession {
  id        String    @id @default(cuid())
  studentId String
  tutorId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  student   User      @relation("StudentChats", fields: [studentId], references: [id])
  tutor     User      @relation("TutorChats", fields: [tutorId], references: [id])
  messages  Message[]

  @@unique([studentId, tutorId])
}

model Message {
  id        String      @id @default(cuid())
  sessionId String
  senderId  String
  content   String
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())
  sender    User        @relation("SentMessages", fields: [senderId], references: [id])
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // LEAD_UNLOCK | NEW_LEAD | NEW_MESSAGE | PAYMENT | SYSTEM
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  category    String
  coverImage  String?
  author      String    @default("TuitionsInIndia")
  readTime    String    @default("5 min read")
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum Role {
  STUDENT
  TUTOR
  INSTITUTE
  ADMIN
}

enum AdType {
  BANNER
  SEARCH_TOP
  SIDEBAR
}

enum SubscriptionTier {
  FREE
  PRO
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  CANCELLED
}

enum LeadStatus {
  OPEN
  CLOSED
  CLOSED_STUDENT
  CLOSED_ADMIN
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ListingType {
  PRIVATE
  GROUP
}

enum LeadType {
  ACADEMIC
  RECRUITMENT
}

enum TrialStatus {
  PENDING
  CONFIRMED
  COMPLETED
  DECLINED
  CANCELLED
}

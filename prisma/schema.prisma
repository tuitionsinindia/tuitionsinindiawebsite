generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String             @id @default(cuid())
  name                String?
  email               String?            @unique
  emailVerified       DateTime?
  image               String?
  googleId            String?            @unique
  provider            String?            @default("phone")
  role                Role               @default(STUDENT)
  phone               String?            @unique
  phoneVerified       Boolean            @default(false)
  isProfileComplete   Boolean            @default(false)
  privacySettings     Json?              @default("{\"showPhonePublicly\": true, \"preferredContact\": \"PHONE\"}")
  notificationPrefs   Json?              @default("{\"emailMatches\": true, \"emailMessages\": true, \"emailPayments\": true, \"smsLeads\": false}")
  lat                 Float?
  lng                 Float?
  isVerified          Boolean            @default(false)
  verificationRequest VerificationRequest?
  isIdVerified        Boolean            @default(false)
  isSuspended         Boolean            @default(false)
  credits             Int                @default(0)
  expoPushToken       String?            // Mobile app push notification token
  platformCredit      Int                @default(0) // demo deposit credits in paise
  contactViewsThisMonth Int             @default(0) // resets 1st of each month
  demoBookingsThisMonth Int              @default(0) // resets 1st of each month
  subscriptionTier    SubscriptionTier   @default(FREE)
  subscriptionStatus  SubscriptionStatus @default(INACTIVE)
  subscriptionId      String?            @unique
  // Set when an early-adopter tutor is auto-granted a complimentary PRO trial.
  // The reset-credits cron downgrades them back to FREE once this date passes.
  proGrantedUntil     DateTime?
  referralCode        String?            @unique
  referredById        String?
  referredBy          User?              @relation("Referrals", fields: [referredById], references: [id])
  referrals           User[]             @relation("Referrals")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  ads                 AdSlot[]           @relation("UserAds")
  studentChats        ChatSession[]      @relation("StudentChats")
  tutorChats          ChatSession[]      @relation("TutorChats")
  courses             Course[]           @relation("InstituteCourses")
  leadsPosted         Lead[]             @relation("LeadCreator")
  leadsUnlocked       LeadUnlock[]
  tutorListing        Listing?
  messagesSent        Message[]          @relation("SentMessages")
  reviewsGiven        Review[]           @relation("ReviewAuthor")
  reviewsReceived     Review[]           @relation("ReviewTarget")
  transactions        Transaction[]
  notifications       Notification[]
  studentTrials       TrialBooking[]     @relation("StudentTrials")
  tutorTrials         TrialBooking[]     @relation("TutorTrials")
  savedTutors         SavedTutor[]       @relation("StudentSavedTutors")
  savedByStudents     SavedTutor[]       @relation("TutorSavedBy")
  vipApplications     VipApplication[]   @relation("VipStudent")
  vipMatchesAsTutor   VipMatch[]         @relation("VipMatchTutor")
  vipContracts        VipContract[]      @relation("VipContractStudent")
  vipContractsAsTutor VipContract[]      @relation("VipContractTutor")

  // Ad attribution — captured at first landing, never overwritten.
  utmSource           String?
  utmMedium           String?
  utmCampaign         String?
  utmContent          String?
  utmTerm             String?
  landingPath         String?
  referrerHost        String?

  @@index([role])
  @@index([createdAt])
  @@index([subscriptionTier])
  @@index([isVerified])
  @@index([utmSource])
  @@index([utmCampaign])
}

// Tickets raised from the chatbot or help pages. type distinguishes
// pre-signup sales enquiries from logged-in user support issues.
model Ticket {
  id              String        @id @default(cuid())
  type            TicketType
  status          TicketStatus  @default(OPEN)
  subject         String
  body            String
  userId          String?       // nullable — anonymous users can still raise tickets
  name            String?
  email           String?
  phone           String?
  sourcePath      String?       // page they were on
  chatTranscript  Json?         // last N messages from chatbot context (if raised from bot)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

enum TicketType {
  SALES
  SUPPORT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SavedTutor {
  id        String   @id @default(cuid())
  studentId String
  tutorId   String
  createdAt DateTime @default(now())
  student   User     @relation("StudentSavedTutors", fields: [studentId], references: [id], onDelete: Cascade)
  tutor     User     @relation("TutorSavedBy", fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([studentId, tutorId])
}

model Listing {
  id               String      @id @default(cuid())
  tutorId          String      @unique
  title            String
  bio              String
  subjects         String[]
  grades           String[]
  locations        String[]
  hourlyRate       Int?
  rating           Float       @default(0)
  reviewCount      Int         @default(0)
  viewCount        Int         @default(0)
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  boards           String[]
  experience       Int?
  gender           String?
  teachingModes    String[]
  timings          String[]
  languages        String[]
  expertiseLevel   String?
  type             ListingType @default(PRIVATE)
  maxSeats         Int?        @default(1)
  enrolledCount    Int         @default(0)
  isInstitute      Boolean     @default(false)
  offersTrialClass Boolean     @default(false)
  trialDuration    Int         @default(30)
  isVipEligible    Boolean     @default(false)
  vipAvailability  Json? // weekly schedule slots for VIP matching
  isFeatured       Boolean     @default(false)
  featuredUntil    DateTime?
  instituteType    String?     // coaching_centre | music_school | language_institute | test_prep | sports_fitness | hobby_craft
  tutor            User        @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([rating])
  @@index([createdAt])
  @@index([hourlyRate])
  @@index([isFeatured])
}

model TrialBooking {
  id               String        @id @default(cuid())
  studentId        String
  tutorId          String
  subject          String
  preferredTime    String
  message          String?
  duration         Int           @default(30)
  status           TrialStatus   @default(PENDING)
  tutorNote        String?
  cancelReason     String?
  // Demo deposit
  depositAmount    Int           @default(14900)   // ₹149 in paise
  depositStatus    DepositStatus @default(UNPAID)
  depositOrderId   String?       @unique
  depositPaymentId String?       @unique
  demoType         DemoType?     // set by tutor on accept: FREE | PAID
  creditUsedFrom   String?       // trialBookingId whose credit funded this booking
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  student          User          @relation("StudentTrials", fields: [studentId], references: [id], onDelete: Cascade)
  tutor            User          @relation("TutorTrials", fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([tutorId])
  @@index([depositStatus])
}

model Lead {
  id               String       @id @default(cuid())
  studentId        String
  subjects         String[]
  grades           String[]
  locations        String[]
  lat              Float?
  lng              Float?
  budget           Int?
  budgetMax        Int?
  modes            String[]
  boards           String[]
  timings          String[]
  genderPreference String?
  description      String
  isPremium        Boolean      @default(false)
  premiumTier      Int          @default(0)
  maxUnlocks       Int          @default(5)
  unlockCount      Int          @default(0)
  status           LeadStatus   @default(OPEN)
  type             LeadType     @default(ACADEMIC)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  student          User         @relation("LeadCreator", fields: [studentId], references: [id], onDelete: Cascade)
  unlockedBy       LeadUnlock[]

  @@index([studentId])
  @@index([status])
  @@index([createdAt])
  @@index([type])
}

model LeadUnlock {
  id         String   @id @default(cuid())
  leadId     String
  tutorId    String
  unlockedAt DateTime @default(now())
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tutor      User     @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([leadId, tutorId])
  @@index([tutorId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  authorId  String
  targetId  String
  createdAt DateTime @default(now())
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id])
}

model Course {
  id            String   @id @default(cuid())
  instituteId   String
  title         String
  description   String
  duration      String
  price         Int
  category      String
  timings       String[]
  maxSeats      Int?     @default(20)
  enrolledCount Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  institute     User     @relation("InstituteCourses", fields: [instituteId], references: [id], onDelete: Cascade)
}

model AdSlot {
  id        String   @id @default(cuid())
  userId    String
  type      AdType
  imageUrl  String?
  targetUrl String?
  startTime DateTime
  endTime   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("UserAds", fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                String            @id @default(cuid())
  userId            String
  amount            Int
  currency          String            @default("INR")
  status            TransactionStatus @default(PENDING)
  razorpayOrderId   String?           @unique
  razorpayPaymentId String?           @unique
  description       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ChatSession {
  id        String    @id @default(cuid())
  studentId String
  tutorId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  student   User      @relation("StudentChats", fields: [studentId], references: [id])
  tutor     User      @relation("TutorChats", fields: [tutorId], references: [id])
  messages  Message[]

  @@unique([studentId, tutorId])
}

model Message {
  id        String      @id @default(cuid())
  sessionId String
  senderId  String
  content   String
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())
  sender    User        @relation("SentMessages", fields: [senderId], references: [id])
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([senderId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // LEAD_UNLOCK | NEW_LEAD | NEW_MESSAGE | PAYMENT | INQUIRY | VIP | SYSTEM
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  category    String
  coverImage  String?
  author      String    @default("TuitionsInIndia")
  readTime    String    @default("5 min read")
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── VIP Managed Tuition Service ───────────────────────────────────────────

model VipApplication {
  id                  String               @id @default(cuid())
  studentId           String
  status              VipApplicationStatus @default(PENDING_PAYMENT)
  // Requirements filled by student
  subjects            String[]
  grades              String[]
  locations           String[]
  budget              Int? // monthly budget in INR
  schedule            String[] // e.g. ["Weekdays 4-6pm", "Weekends morning"]
  genderPreference    String? // MALE | FEMALE | ANY
  boardPreference     String?
  modePreference      String? // ONLINE | OFFLINE | BOTH
  additionalNotes     String?
  // Enrollment payment (₹2,000 = 200000 paise)
  enrollmentFee       Int                  @default(200000)
  enrollmentOrderId   String?              @unique
  enrollmentPaymentId String?              @unique
  // Matching state
  currentMatchNumber  Int                  @default(0) // 0 = no match sent yet
  replacementsUsed    Int                  @default(0)
  maxReplacements     Int                  @default(3)
  maxRecommendations  Int                  @default(5)
  // Admin notes
  adminNotes          String?
  assignedAdminId     String?
  // Relations
  student             User                 @relation("VipStudent", fields: [studentId], references: [id], onDelete: Cascade)
  matches             VipMatch[]
  contract            VipContract?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([studentId])
  @@index([status])
  @@index([createdAt])
}

model VipMatch {
  id                   String         @id @default(cuid())
  applicationId        String
  tutorId              String
  recommendationNumber Int // 1–5
  status               VipMatchStatus @default(SENT)
  // Student response
  studentNote          String? // reason for rejection
  respondedAt          DateTime?
  // Intro call
  introCallUrl         String? // Google Meet link
  introCallScheduledAt DateTime?
  introCallNotes       String?
  // Relations
  application          VipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tutor                User           @relation("VipMatchTutor", fields: [tutorId], references: [id], onDelete: Cascade)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([applicationId, tutorId])
  @@index([applicationId])
  @@index([tutorId])
  @@index([status])
}

model VipContract {
  id               String            @id @default(cuid())
  applicationId    String            @unique
  studentId        String
  tutorId          String
  // Financial terms
  monthlyFee       Int // what student pays platform per month (paise)
  tutorPayout      Int // what tutor receives (85% of monthlyFee)
  platformCut      Int // platform commission (15%)
  // Contract terms
  startDate        DateTime          @default(now())
  endDate          DateTime? // null = ongoing
  status           VipContractStatus @default(ACTIVE)
  replacementsUsed Int               @default(0)
  replacementsLeft Int               @default(3)
  // Notes
  contractNotes    String?
  // Relations
  application      VipApplication    @relation(fields: [applicationId], references: [id])
  student          User              @relation("VipContractStudent", fields: [studentId], references: [id])
  tutor            User              @relation("VipContractTutor", fields: [tutorId], references: [id])
  payments         VipPayment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([studentId])
  @@index([tutorId])
  @@index([status])
}

model VipPayment {
  id                String           @id @default(cuid())
  contractId        String
  amount            Int // paise
  tutorPayout       Int
  platformCut       Int
  status            VipPaymentStatus @default(PENDING)
  razorpayOrderId   String?          @unique
  razorpayPaymentId String?          @unique
  dueDate           DateTime
  paidAt            DateTime?
  failureReason     String?
  contract          VipContract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())

  @@index([contractId])
  @@index([status])
  @@index([dueDate])
}

model VerificationRequest {
  id                String             @id @default(cuid())
  tutorId           String             @unique
  status            VerificationStatus @default(PENDING_PAYMENT)
  razorpayOrderId   String?            @unique
  razorpayPaymentId String?            @unique
  rejectionReason   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tutor             User               @relation(fields: [tutorId], references: [id])

  @@index([status])
}

// ─── VIP Enums ──────────────────────────────────────────────────────────────

enum VipApplicationStatus {
  PENDING_PAYMENT // Application started, awaiting ₹2,000 payment
  ACTIVE // Paid, matching in progress
  MATCHED // Student has confirmed a tutor, contract active
  COMPLETED // Contract ended naturally
  REFUNDED // All 5 recommendations rejected, refunded
  CANCELLED // Cancelled by student or admin
}

enum VipMatchStatus {
  SENT // Recommendation sent to student
  ACCEPTED // Student wants to proceed with this tutor
  REJECTED // Student rejected this tutor
  EXPIRED // Student didn't respond in time
}

enum VipContractStatus {
  ACTIVE
  PAUSED // Temporarily paused (e.g. school break)
  TERMINATED // Ended early
  COMPLETED // Natural end
}

enum VipPaymentStatus {
  PENDING
  PAID
  FAILED
}

enum Role {
  STUDENT
  TUTOR
  INSTITUTE
  ADMIN
}

enum AdType {
  BANNER
  SEARCH_TOP
  SIDEBAR
}

enum SubscriptionTier {
  FREE
  PRO
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  CANCELLED
}

enum LeadStatus {
  OPEN
  CLOSED
  CLOSED_STUDENT
  CLOSED_ADMIN
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ListingType {
  PRIVATE
  GROUP
}

enum LeadType {
  ACADEMIC
  RECRUITMENT
}

enum TrialStatus {
  PENDING
  CONFIRMED
  COMPLETED
  DECLINED
  CANCELLED
}

enum DepositStatus {
  UNPAID      // Booking created, deposit not yet paid
  PAID        // ₹149 held by platform
  CREDITED    // Returned as platformCredit to student (free demo completed)
  RELEASED    // Paid out to tutor (paid demo or no-show)
  REFUNDED    // Booking cancelled before demo, full refund
  TRANSFERRED // Student's credit was applied to a new booking
}

enum DemoType {
  FREE  // Tutor offers free demo; deposit returned as student platform credit
  PAID  // Tutor charges ₹149; ₹119 credited to tutor ledger, ₹30 kept by platform
}

enum VerificationStatus {
  PENDING_PAYMENT  // Razorpay order created, not yet paid
  PENDING_REVIEW   // Payment done, awaiting admin review
  APPROVED         // Admin approved — isVerified set to true
  REJECTED         // Admin rejected with reason
}

// ─── Platform Goals & Roadmap ──────────────────────────────────────────────

model PlatformGoal {
  id          String   @id @default(cuid())
  title       String
  category    String   // REVENUE | TUTORS | STUDENTS | CONVERSIONS
  targetValue Float
  deadline    DateTime
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Monthly Ad Budget Tracking ────────────────────────────────────────────

model MonthlyBudget {
  id          String   @id @default(cuid())
  month       String   // "2026-04" format
  totalBudget Int      // rupees
  adSpend     Int      @default(0) // actual spend, manual entry
  breakdown   Json?    // { facebook: 10000, google: 8000, whatsapp: 0, other: 2000 }
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([month])
}

// ─── Weekly Admin Insights ─────────────────────────────────────────────────

model AdminInsight {
  id          String   @id @default(cuid())
  weekOf      DateTime
  category    String   // REVENUE | GROWTH | CONVERSION | BUDGET | ALERT
  priority    String   // HIGH | MEDIUM | LOW
  title       String
  body        String
  action      String?  // suggested next action
  metric      String?  // key metric name that triggered this
  metricValue Float?   // value of that metric
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

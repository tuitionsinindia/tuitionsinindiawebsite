4\">\n<button class=\"flex flex-col items-center gap-4 p-6 bg-white dark:bg-slate-800 rounded-xl shadow-sm hover:shadow-md transition-all border border-slate-100 dark:border-slate-700 group\">\n<div class=\"size-14 rounded-full bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center text-primary dark:text-blue-400 group-hover:scale-110 transition-transform\">\n<span class=\"material-symbols-outlined text-3xl\">menu_book</span>\n</div>\n<span class=\"font-bold text-sm\">K-12 Education</span>\n</button>\n<button class=\"flex flex-col items-center gap-4 p-6 bg-white dark:bg-slate-800 rounded-xl shadow-sm hover:shadow-md transition-all border border-slate-100 dark:border-slate-700 group\">\n<div class=\"size-14 rounded-full bg-red-50 dark:bg-red-900/30 flex items-center justify-center text-red-600 dark:text-red-400 group-hover:scale-110 transition-transform\">\n<span class=\"material-symbols-outlined text-3xl\">science</span>\n</div>\n<span class=\"font-bold text-sm\">JEE/NEET Prep</span>\n</button>\n<button class=\"flex flex-col items-center gap-4 p-6 bg-white dark:bg-slate-800 rounded-xl shadow-sm hover:shadow-md transition-all border border-slate-100 dark:border-slate-700 group\">\n<div class=\"size-14 rounded-full bg-amber-50 dark:bg-amber-900/30 flex items-center justify-center text-amber-600 dark:text-amber-400 group-hover:scale-110 transition-transform\">\n<span class=\"material-symbols-outlined text-3xl\">gavel</span>\n</div>\n<span class=\"font-bold text-sm\">UPSC &amp; Govt</span>\n</button>\n<button class=\"flex flex-col items-center gap-4 p-6 bg-white dark:bg-slate-800 rounded-xl shadow-sm hover:shadow-md transition-all border border-slate-100 dark:border-slate-700 group\">\n<div class=\"size-14 rounded-full bg-emerald-50 dark:bg-emerald-900/30 flex items-center justify-center text-emerald-600 dark:text-emerald-400 group-hover:scale-110 transition-transform\">\n<span class=\"material-symbols-outlined text-3xl\">terminal</span>\n</div>\n<span class=\"font-bold text-sm\">Coding &amp; Tech</span>\n</button>\n<button class=\"flex flex-col items-center gap-4 p-6 bg-white dark:bg-slate-800 rounded-xl shadow-sm hover:shadow-md transition-all border border-slate-100 dark:border-slate-700 group\">\n<div class=\"size-14 rounded-full bg-purple-50 dark:bg-purple-900/30 flex items-center justify-center text-purple-600 dark:text-purple-400 group-hover:scale-110 transition-transform\">\n<span class=\"material-symbols-outlined text-3xl\">translate</span>\n</div>\n<span class=\"font-bold text-sm\">Languages</span>\n</button>\n</div>\n</div>\n</section>\n<!-- Verified Tutors Section -->\n<section class=\"py-20 bg-white dark:bg-background-dark\">\n<div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n<div class=\"text-center max-w-3xl mx-auto mb-16\">\n<h2 class=\"text-3xl font-bold mb-4\">Meet Our Verified Top-Rated Tutors</h2>\n<p class=\"text-slate-600 dark:text-slate-400\">We handpick tutors based on their academic background, teaching experience, and communication skills.</p>\n</div>\n<div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8\">\n<!-- Tutor Card 1 -->\n<div class=\"group bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-2xl transition-all duration-300\">\n<div class=\"relative h-64 overflow-hidden\">\n<img class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-110\" data-alt=\"Professional Indian male tutor in office attire\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBNyPIvzVpiWppa2rTiBjvjqEIJJisVdAfI5-fS17eeX5hCub29XWhi0bG0bsZ49Z2p8opi_YnIuvQY3Vis7QHQo1TY7eb41OQqzt4rkmTrSR6LvnpcJWMfg0ZX9GpdEyEmODcwGPrke0H4dUv5RbGW5Z-l-kpC8vx-ub4mxMpUQbcoZbUIfPWTxcT6bm1Ku0067Rs4KCW_Nk4Sk9FeVq288Qsi0mf1RJygeG4LUnOqYDAwt92MN9a1OlQ6yCFSBrUcCkrsPKCogl8\"/>\n<div class=\"absolute top-4 left-4 bg-primary text-white text-[10px] font-bold px-2 py-1 rounded uppercase\">Verified</div>\n</div>\n<div class=\"p-6\">\n<div class=\"flex justify-between items-start mb-2\">\n<h4 class=\"font-bold text-lg\">Dr. Rajesh Kumar</h4>\n<div class=\"flex items-center gap-1 text-accent\">\n<span class=\"material-symbols-outlined text-sm\">star</span>\n<span class=\"text-sm font-bold\">4.9</span>\n</div>\n</div>\n<p class=\"text-sm text-slate-500 mb-4\">Physics &amp; Mathematics (IIT Grad)</p>\n<div class=\"flex items-center justify-between pt-4 border-t border-slate-100 dark:border-slate-700\">\n<div class=\"text-primary font-bold\">₹800<span class=\"text-xs font-normal text-slate-500\">/hr</span></div>\n<button class=\"text-sm font-bold text-primary group-hover:underline\">View Profile</button>\n</div>\n</div>\n</div>\n<!-- Tutor Card 2 -->\n<div class=\"group bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-2xl transition-all duration-300\">\n<div class=\"relative h-64 overflow-hidden\">\n<img class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-110\" data-alt=\"Professional Indian female tutor smiling\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBfGzWRaKaBK5rDMwzBLBulRbkZfb7BoriJRBgFGFFpBV3WonXaLmpvwY9qczTu5GRKxs5RFXHJCFPd6fapod09z9d4W8pQjElq5jsWBccf_6ozAPohFXfbHLwwcOz3G6PSybG6Yl65Vn9g4fCKFkVP-iKqQ1v3ZYMxg7TOOL9nSLCfuwckzUe_yX22pNogBNuYQI88nJkRPKrG7LmJD8cQdrIFrXO3lsg-sE6F8QoNAPICJMtlAKiiZkjFJj9fD1kXJHa9rPG7-HE\"/>\n<div class=\"absolute top-4 left-4 bg-primary text-white text-[10px] font-bold px-2 py-1 rounded uppercase\">Verified</div>\n</div>\n<div class=\"p-6\">\n<div class=\"flex justify-between items-start mb-2\">\n<h4 class=\"font-bold text-lg\">Priya Sharma</h4>\n<div class=\"flex items-center gap-1 text-accent\">\n<span class=\"material-symbols-outlined text-sm\">star</span>\n<span class=\"text-sm font-bold\">4.8</span>\n</div>\n</div>\n<p class=\"text-sm text-slate-500 mb-4\">English &amp; Social Studies (MA English)</p>\n<div class=\"flex items-center justify-between pt-4 border-t border-slate-100 dark:border-slate-700\">\n<div class=\"text-primary font-bold\">₹600<span class=\"text-xs font-normal text-slate-500\">/hr</span></div>\n<button class=\"text-sm font-bold text-primary group-hover:underline\">View Profile</button>\n</div>\n</div>\n</div>\n<!-- Tutor Card 3 -->\n<div class=\"group bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-2xl transition-all duration-300\">\n<div class=\"relative h-64 overflow-hidden\">\n<img class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-110\" data-alt=\"Young Indian male tutor with glasses\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAmrQb0p4H0CMhDwW6BxxPyWYqqAgBwviKa7mf5Be-3cdML3f_cazu7JN6cIZ-By68NQQUifdAFG2EmtbS9ENwOjIlEKAGGC8yj8cynx9NZDNFXvMadRhdGpTyd-yDJFS8aaQQJ0bv7J-JO3y5342Z7T6U5WO_s0juhD6z8seQVuS5OpTyLpK9rhyZIcPibFCxeROhxm0cX_mplfKw6Glzq80cjvZSl5M8ffsTwvIrScc6eDDfWATN1s0k_46Lc0cdcRfXM1492Ehs\"/>\n<div class=\"absolute top-4 left-4 bg-primary text-white text-[10px] font-bold px-2 py-1 rounded uppercase\">Verified</div>\n</div>\n<div class=\"p-6\">\n<div class=\"flex justify-between items-start mb-2\">\n<h4 class=\"font-bold text-lg\">Amit Verma</h4>\n<div class=\"flex items-center gap-1 text-accent\">\n<span class=\"material-symbols-outlined text-sm\">star</span>\n<span class=\"text-sm font-bold\">5.0</span>\n</div>\n</div>\n<p class=\"text-sm text-slate-500 mb-4\">Python, Java &amp; Full-Stack</p>\n<div class=\"flex items-center justify-between pt-4 border-t border-slate-100 dark:border-slate-700\">\n<div class=\"text-primary font-bold\">₹1200<span class=\"text-xs font-normal text-slate-500\">/hr</span></div>\n<button class=\"text-sm font-bold text-primary group-hover:underline\">View Profile</button>\n</div>\n</div>\n</div>\n<!-- Tutor Card 4 -->\n<div class=\"group bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden hover
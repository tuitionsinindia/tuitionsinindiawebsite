  "htmlContent": "<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>TutorIndia | Find Expert Tutors for K-12, JEE, NEET &amp; More</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"primary\": \"#0d40a5\", // Professional Navy\n                        \"accent\": \"#d4af37\",  // Gold Accent\n                        \"background-light\": \"#f6f6f8\",\n                        \"background-dark\": \"#101622\",\n                    },\n                    fontFamily: {\n                        \"display\": [\"Inter\", \"sans-serif\"]\n                    },\n                    borderRadius: {\n                        \"DEFAULT\": \"0.25rem\",\n                        \"lg\": \"0.5rem\",\n                        \"xl\": \"0.75rem\",\n                        \"full\": \"9999px\"\n                    },\n                },\n            },\n        }\n    </script>\n<style>\n        body { font-family: 'Inter', sans-serif; }\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n    </style>\n</head>\n<body class=\"bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display\">\n<!-- Top Navigation Bar -->\n<header class=\"sticky top-0 z-50 w-full border-b border-slate-200 dark:border-slate-800 bg-white/90 dark:bg-background-dark/90 backdrop-blur-md\">\n<div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n<div class=\"flex h-16 items-center justify-between\">\n<div class=\"flex items-center gap-2\">\n<div class=\"text-primary dark:text-blue-400\">\n<span class=\"material-symbols-outlined text-3xl font-bold\">school</span>\n</div>\n<h1 class=\"text-xl font-bold tracking-tight text-primary dark:text-white\">TutorIndia</h1>\n</div>\n<nav class=\"hidden md:flex items-center gap-8\">\n<a class=\"text-sm font-medium hover:text-primary transition-colors\" href=\"#\">Find Tutors</a>\n<a class=\"text-sm font-medium hover:text-primary transition-colors\" href=\"#\">Categories</a>\n<a class=\"text-sm font-medium hover:text-primary transition-colors\" href=\"#\">How it Works</a>\n<a class=\"text-sm font-medium hover:text-primary transition-colors\" href=\"#\">Reviews</a>\n</nav>\n<div class=\"flex items-center gap-3\">\n<button class=\"hidden sm:flex text-sm font-semibold text-primary hover:text-primary/80 px-4 py-2\">Login</button>\n<button class=\"bg-primary text-white text-sm font-bold px-5 py-2.5 rounded-lg hover:bg-primary/90 transition-all shadow-md\">Join as Tutor</button>\n</div>\n</div>\n</div>\n</header>\n<main>\n<!-- Hero Section -->\n<section class=\"relative bg-white dark:bg-background-dark overflow-hidden border-b border-slate-100 dark:border-slate-800\">\n<div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24 flex flex-col lg:flex-row items-center gap-12\">\n<div class=\"flex-1 space-y-8 text-center lg:text-left\">\n<div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wider\">\n<span class=\"material-symbols-outlined text-sm\">verified_user</span>\n                        India's Most Trusted Learning Platform\n                    </div>\n<h2 class=\"text-4xl sm:te